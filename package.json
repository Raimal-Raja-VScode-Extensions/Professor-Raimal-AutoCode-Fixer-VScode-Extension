{
  "name": "professor-raimal-auto-code-fixer",
  "displayName": "Professor Raimal Raja — AI Error Fixer",
  "description": "Automatically detects terminal errors and fixes them using Gemini AI — free, no API key required.",
  "version": "1.1.0",
  "publisher": "Professor-Raimal",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": ["Other", "Programming Languages"],
  "keywords": ["error", "fix", "AI", "terminal", "debug", "gemini"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "professor-raimal-raja.fixError",
        "title": "✨ Professor Raimal-Raja: Fix This Error"
      },
      {
        "command": "professor-raimal-raja.analyzeTerminal",
        "title": "✨ Professor Raimal-Raja: Analyze Terminal"
      }
    ],
    "menus": {
      "terminal/context": [
        {
          "command": "professor-raimal-raja.analyzeTerminal",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Professor Raimal Raja",
      "properties": {
        "professorRaimal.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect errors in the terminal"
        }
      }
    }
  },
  "scripts": {
  "vscode:prepublish": "npm run compile",
  "compile": "tsc -p ./",
  "watch": "tsc -watch -p ./",
  "watch:tsc": "tsc -watch -p ./",
  "watch:esbuild": "tsc -watch -p ./",
  "package": "vsce package",
  "publish": "vsce publish"
},
  "devDependencies": {
   "@types/vscode": "^1.93.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  }
}